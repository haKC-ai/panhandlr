{
  "name": "key_photos",
  "description": "Find organic social media posts where people photograph their physical keys",
  "dorks": [
    {
      "name": "reddit_native",
      "category": "social_media",
      "queries": [
        "my new house keys",
        "got the keys to my new house",
        "new apartment keys",
        "my car key photo",
        "house key copy made",
        "office keys first day",
        "accidentally used the wrong key"
      ]
    },
    {
      "name": "google_reddit",
      "category": "google",
      "queries": [
        "site:reddit.com/r/mildlyinteresting key photo",
        "site:reddit.com \"my keys\" -\"lost my keys\" -\"locked out\"",
        "site:reddit.com \"got my keys\" OR \"new keys\" OR \"house keys\" photo",
        "site:reddit.com \"key\" \"first day\" photo",
        "site:reddit.com/r/pics house key photo"
      ]
    },
    {
      "name": "google_linkedin",
      "category": "google",
      "queries": [
        "site:linkedin.com \"got my keys\" OR \"received my keys\" OR \"new office keys\"",
        "site:linkedin.com \"first day\" keys photo",
        "site:linkedin.com \"handed the keys\" OR \"here are my keys\"",
        "site:linkedin.com \"new home\" keys -stock"
      ]
    },
    {
      "name": "google_twitter",
      "category": "google",
      "queries": [
        "site:twitter.com \"my keys\" photo -lost -found",
        "site:x.com \"new keys\" pic.twitter.com",
        "site:twitter.com \"got the keys\" pic.twitter"
      ]
    },
    {
      "name": "google_image_hosts",
      "category": "google",
      "queries": [
        "site:imgur.com key house OR door OR office",
        "site:flickr.com \"house key\" OR \"door key\" photo",
        "site:postimg.cc key photograph",
        "\"duplicate key\" OR \"spare key\" photo filetype:jpg -site:shutterstock.com -site:getty.com"
      ]
    },
    {
      "name": "google_metadata",
      "category": "metadata",
      "queries": [
        "filetype:jpg \"key\" exif GPS",
        "filetype:jpg inurl:key -background -wallpaper -icon"
      ]
    }
  ]
}
